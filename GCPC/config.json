{
  "backend": "mediapipe",
  "models_dir": "models",
  "onnx": {
    "detector_model": "palm_detection.onnx",
    "detector_input_size": [256, 256],
    "landmark_model": "hand_landmarks.onnx",
    "landmark_input_size": [224, 224],
    "max_hands": 2,
    "score_threshold": 0.3,
    "nms_threshold": 0.45,
    "presence_threshold": 0.35,
    "smooth": true
  },
  "detector": {
    "backend": "mediapipe",
    "min_detection_confidence": 0.6,
    "min_tracking_confidence": 0.5,
    "max_num_hands": 2,
    "model_complexity": 1
  },
  "dominant_hand": "right",
  "video": {
    "camera_index": 0,
    "width": 1280,
    "height": 720,
    "mirror": true
  },
  "sounds": {
    "on_toggle": false,
    "on_commit": false,
    "on_send": false
  },
  "gesture_engine": {
    "clutch": "none",
    "cooldown_ms": 420,
    "pinch_threshold": 0.045,
    "fist_threshold": 0.35,
    "thumbs_up_thumb_max_flex": 0.35,
    "thumbs_up_others_min_flex": 0.5,
    "point_index_max_flex": 0.3,
    "point_others_min_flex": 0.5,
    "swipe_speed_px": 900
  },
  "sequence": {
    "arm_delay_ms": 420,
    "refractory_ms": 1100,
    "no_repeat_ms": 650,
    "cancel_on_hand_exit_ms": 900,
    "auto_exit_on_hand_exit": true,
    "max_len": 6,
    "exit_on_commit": true
  },
  "bimanual": {
    "confirm_dwell_ms": 220,
    "confirm_refractory_ms": 700,
    "undo_window_ms": 900,
    "commit_dwell_ms": 260,
    "commit_refractory_ms": 1200
  },
  "sequence_mappings": {
    "POINT+FIST": "CTRL+ALT+T",
    "OPEN_PALM+FIST": "ALT+F4",
    "PINCH_TAP": "CTRL+C",
    "PINCH_HOLD": "CTRL+V",
    "SWIPE_LEFT+SWIPE_RIGHT": "ALT+TAB"
  }
}