{
  "video": {
    "roi": [
      0.15,
      0.25,
      0.7,
      0.6
    ],
    "camera_index": 1,
    "width": 640,
    "height": 360,
    "fps_min": 60,
    "exposure_auto": true,
    "camera_backend": "msmf"
  },
  "gesture": {
    "conf_min": 0.5,
    "min_duration_ms": 100,
    "max_duration_ms": 600,
    "cooldown_ms": 250,
    "thr_swipe": 0.22,
    "thr_tapz": 0.05
  },
  "clutch": {
    "type": "pinch",
    "window_ms": 2500,
    "pinch_open": 0.3,
    "pinch_close": 0.22,
    "hold_ms": 80
  },
  "mapping": {
    "swipe_up": [
      "CTRL",
      "C"
    ],
    "swipe_down": [
      "CTRL",
      "V"
    ],
    "tap_forward": [
      "CTRL",
      "X"
    ],
    "tap_back": [
      "CTRL",
      "Z"
    ]
  },
  "telemetry": {
    "log_level": "info",
    "dir": "logs",
    "file_prefix": "session"
  },
  "hud": {
    "enabled": true
  },
  "models": {
    "hand_landmark": "models/hand_landmarker.onnx",
    "palm_detector": "models/palm_detection.onnx"
  },
 "tracker_opts": {
    "det_every": 5,
    "min_det_conf": 0.50,
    "presence_high": 0.80,
    "presence_low": 0.60,
    "k_enter": 2,
    "k_exit": 2,
    "min_box_area": 0.015,
    "pad_scale": 1.3,
    "lost_grace_frames": 1,
    "z_div": 80.0,
    "z_dir": -1
  }
}