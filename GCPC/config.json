{
  "backend": "mediapipe",
  "onnx_landmarks": true,
  "detector": {
    "backend": "mediapipe",
    "min_detection_confidence": 0.6,
    "min_tracking_confidence": 0.5,
    "max_num_hands": 2,
    "model_complexity": 1
  },
  "dominant_hand": "right",
  "video": {
    "camera_index": 0,
    "width": 1280,
    "height": 720,
    "mirror": true,
    "show_fps": true
  },
  "sounds": {
    "on_toggle": false,
    "on_commit": false,
    "on_send": false
  },
  "gesture_engine": {
    "clutch": "none",
    "cooldown_ms": 420,
    "pinch_threshold": 0.045,
    "fist_threshold": 0.35,
    "thumbs_up_thumb_max_flex": 0.35,
    "thumbs_up_others_min_flex": 0.5,
    "point_index_max_flex": 0.3,
    "point_others_min_flex": 0.5,
    "swipe_speed_px": 900
  },
  "sequence": {
    "arm_delay_ms": 420,
    "refractory_ms": 1100,
    "no_repeat_ms": 650,
    "cancel_on_hand_exit_ms": 900,
    "auto_exit_on_hand_exit": true,
    "max_len": 6,
    "exit_on_commit": true
  },
  "bimanual": {
    "confirm_dwell_ms": 220,
    "confirm_refractory_ms": 700,
    "undo_window_ms": 900,
    "commit_dwell_ms": 260,
    "commit_refractory_ms": 1200
  },
  "one_hand_mode": {
    "enabled": true,
    "status_label": "ONE-HAND",
    "active_hint": "LEFT FIST → SINGLE"
  },
  "mouse_control": {
    "enabled": true,
    "status_label": "MOUSE",
    "active_hint": "LEFT THUMBS UP | CURSOR: RIGHT POINT | LMB: FIST | RMB: OPEN PALM",
    "smoothing_alpha": 0.25,
    "pointer_hand": "right"
  },
  "mode_switches": {
    "refractory_ms": 800,
    "one_hand": {
      "hand": "non_dominant",
      "gesture": "FIST"
    },
    "record": {
      "hand": "both",
      "gesture": "OPEN_PALM"
    },
    "mouse": {
      "hand": "non_dominant",
      "gesture": "THUMBS_UP"
    },
    "exit": {
      "hand": "non_dominant",
      "gesture": "SWIPE_LEFT"
    }
  },
  "command_mappings": {
    "functional": {
      "MODE_ONE_HAND": "LEFT FIST",
      "MODE_RECORD": "BOTH OPEN PALMS",
      "MODE_MOUSE": "LEFT THUMBS UP",
      "MODE_EXIT": "LEFT SWIPE LEFT",
      "CONFIRM_STEP": "LEFT_PINCH_TAP",
      "UNDO_STEP": "LEFT_OPEN_PALM→LEFT_FIST",
      "COMMIT_SEQUENCE": "FIST+FIST"
    },
    "complex_gestures": {
      "POINT+FIST": "CTRL+ALT+T",
      "OPEN_PALM+FIST": "ALT+F4",
      "SWIPE_LEFT+SWIPE_RIGHT": "ALT+TAB"
    },
    "single_gestures": {
      "PINCH_TAP": "CTRL+C",
      "PINCH_HOLD": "CTRL+V"
    }
  }
}
